{
  "name": "milk-website",
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "public": true,
  "env": [],
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/code.html"
    }
  ]
}
